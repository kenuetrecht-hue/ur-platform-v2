# =========================================================================
# UR MEDIA LLC - ENTERPRISE MEDIA INFRASTRUCTURE CONFIGURATION
# =========================================================================
# Copy this file to .env.local and fill in your actual credentials

# AWS S3 Configuration
# Get these from your AWS IAM user credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_MEDIA_BUCKET=ur-media-production-bucket

# AWS MediaConvert Configuration (for adaptive HLS transcoding)
# Get the endpoint from AWS MediaConvert console
AWS_MEDIACONVERT_ENDPOINT=https://abcdefg.mediaconvert.us-east-1.amazonaws.com
AWS_MEDIACONVERT_ROLE_ARN=arn:aws:iam::123456789012:role/MediaConvertRole
AWS_MEDIACONVERT_QUEUE=Default

# Cloudflare CDN Configuration
# This is your custom CDN domain for global content delivery
CLOUDFLARE_CDN_DOMAIN=https://cdn.urmediallc.com

# Optional: Cloudflare API for cache purging
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# =========================================================================
# SETUP INSTRUCTIONS
# =========================================================================

# 1. AWS S3 BUCKET SETUP:
#    - Create S3 bucket: ur-media-production-bucket
#    - Enable versioning for data protection
#    - Set CORS policy to allow uploads from your domain
#    - Enable CloudFront distribution for CDN

# 2. AWS MEDIACONVERT SETUP:
#    - Create MediaConvert job templates for HLS transcoding
#    - Create IAM role with MediaConvert permissions
#    - Set up SNS notifications for job completion

# 3. CLOUDFLARE SETUP:
#    - Create CNAME record pointing to S3 bucket
#    - Enable Argo Smart Routing for optimal performance
#    - Set up cache rules for media content
#    - Enable HTTP/2 and Brotli compression

# 4. CORS POLICY FOR S3:
# {
#   "CORSRules": [
#     {
#       "AllowedHeaders": ["*"],
#       "AllowedMethods": ["GET", "PUT", "POST", "DELETE", "HEAD"],
#       "AllowedOrigins": ["https://urmediallc.com", "https://www.urmediallc.com"],
#       "ExposeHeaders": ["ETag"],
#       "MaxAgeSeconds": 3000
#     }
#   ]
# }

# 5. S3 BUCKET POLICY:
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Principal": "*",
#       "Action": "s3:GetObject",
#       "Resource": "arn:aws:s3:::ur-media-production-bucket/*",
#       "Condition": {
#         "StringLike": {
#           "aws:Referer": "https://urmediallc.com/*"
#         }
#       }
#     }
#   ]
# }
